{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Live Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=3000", "--no-browser"],
      "port": 3000
    },
    {
      "name": "HTTP Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", ".", "-p", "8080", "--cors", "-c-1"],
      "port": 8080
    },
    {
      "name": "Python HTTP Server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    }
  ]
}
